{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "nix": {
    "enabled": true
  },
  "labels": ["dependencies"],
  "ignorePaths": ["deploy/**"],
  "platformAutomerge": false,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 06:00 on Saturday"]
  },
  "packageRules": [
    {
      "matchManagers": ["uv"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "overrideDepName": "uv lock file maintenance",
      "groupName": "uv lock file maintenance",
      "commitMessageTopic": "uv lock file"
    },
    {
      "matchManagers": ["nix"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "overrideDepName": "nix lock file maintenance",
      "groupName": "nix lock file maintenance",
      "commitMessageTopic": "nix flake lock file"
    },
    {
      "matchManagers": ["github-actions", "nix"],
      "matchUpdateTypes": ["digest", "pin", "patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "matchManagers": ["nix"],
      "groupName": "nix flake inputs"
    },
    {
      "matchManagers": ["uv", "pep621"],
      "groupName": "opentelemetry",
      "matchPackageNames": [
        "/^opentelemetry-/"
      ]
    },
    {
      "matchManagers": ["uv", "pep621"],
      "matchPackageNames": ["pydantic", "pydantic-settings"],
      "groupName": "pydantic"
    },
    {
      "matchManagers": ["uv", "pep621"],
      "matchPackageNames": ["flask", "werkzeug", "jinja2", "itsdangerous"],
      "groupName": "flask stack"
    },
    {
      "matchManagers": ["uv", "pep621"],
      "rangeStrategy": "pin",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchManagers": ["pep621"],
      "matchDepNames": ["python"],
      "enabled": false
    }
  ]
}
