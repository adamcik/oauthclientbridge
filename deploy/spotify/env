FLASK_SECRET_KEY=REDACTED

FLASK_SESSION_COOKIE_DOMAIN=auth.mopidy.com
FLASK_SESSION_COOKIE_PATH=/spotify
FLASK_SESSION_COOKIE_SECURE=true

BRIDGE_NUM_PROXIES=1

DB_PRAGMAS=["PRAGMA journal_mode = WAL","PRAGMA synchronous = NORMAL"]
DB_TIMEOUT=10

FETCH_TIMEOUT=30

OAUTH_CLIENT_ID=REDACTED
OAUTH_CLIENT_SECRET=REDACTED

OAUTH_AUTHORIZATION_URI=https://accounts.spotify.com/authorize?show_dialog=true
OAUTH_REDIRECT_URI=https://auth.mopidy.com/spotify/callback
OAUTH_REFRESH_URI=https://accounts.spotify.com/api/token
OAUTH_SCOPES=["playlist-modify-public","playlist-modify-private","playlist-read-private","playlist-read-collaborative","user-follow-read","user-library-read","user-library-modify","user-read-recently-played","user-read-private","user-top-read","streaming"]
OAUTH_TOKEN_URI=https://accounts.spotify.com/api/token

# Temporary workaround for clients that keep retrying locally revoked grants
# until they observe a Spotify Web API 401.
# REVOKED_GRANT_WORKAROUND_USER_AGENTS=^Mopidy-Spotify/
# REVOKED_GRANT_WORKAROUND_ACCESS_TOKEN=MOPIDY_SPOTIFY_REVOKED_GRANT_WORKAROUND
# REVOKED_GRANT_WORKAROUND_EXPIRES_IN=300

SENTRY_ENABLED=true
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.0001

SENTRY_DSN=REDACTED

TELEMETRY_COMPONENTS=["tracing"]
TELEMETRY_EXPORTERS=["otlp_http"]
TELEMETRY_ENDPOINT=http://127.0.0.1:4318/v1/traces
TELEMETRY_OAUTH_PROVIDER=spotify
TELEMETRY_DEPLOYMENT_ENVIRONMENT=spotify

WORKERS=4
THREADS=2
