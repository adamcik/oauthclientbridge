# Required app settings
FLASK_SECRET_KEY=replace-me
DB_DATABASE=/data/sqlite.db
OAUTH_CLIENT_ID=replace-me
OAUTH_CLIENT_SECRET=replace-me
OAUTH_AUTHORIZATION_URI=https://provider.example.com/auth
OAUTH_TOKEN_URI=https://provider.example.com/token

# Optional bridge/proxy settings
# BRIDGE_NUM_PROXIES=1
# FLASK_SESSION_COOKIE_SECURE=true

# Optional Sentry
# SENTRY_ENABLED=true
# SENTRY_DSN=https://examplePublicKey@example.ingest.sentry.io/1
# SENTRY_SAMPLE_RATE=1.0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry (optional)
# TELEMETRY_COMPONENTS=tracing,metrics
# TELEMETRY_EXPORTERS=otlp_grpc
# TELEMETRY_ENDPOINT=http://otel-collector:4317
# TELEMETRY_SERVICE_NAME=oauthclientbridge

# Prometheus multiprocess mode (required if running multiple workers/processes)
PROMETHEUS_MULTIPROC_DIR=/var/lib/oauthclientbridge/prom-multiproc

# Container runtime knobs consumed by image entrypoint
WORKERS=4
THREADS=2
