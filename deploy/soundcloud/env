FLASK_SECRET_KEY=REDACTED

FLASK_SESSION_COOKIE_DOMAIN=auth.mopidy.com
FLASK_SESSION_COOKIE_PATH=/soundcloud
FLASK_SESSION_COOKIE_SECURE=true

BRIDGE_NUM_PROXIES=1

DB_PRAGMAS=["PRAGMA journal_mode = WAL","PRAGMA synchronous = NORMAL"]
DB_TIMEOUT=10

FETCH_TIMEOUT=30

OAUTH_CLIENT_ID=REDACTED
OAUTH_CLIENT_SECRET=REDACTED

OAUTH_AUTHORIZATION_URI=https://api.soundcloud.com/connect
OAUTH_REDIRECT_URI=https://www.mopidy.com/soundcloud_callback
OAUTH_REFRESH_URI=https://api.soundcloud.com/oauth2/token
OAUTH_TOKEN_URI=https://api.soundcloud.com/oauth2/token

SENTRY_ENABLED=true
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.0001

SENTRY_DSN=REDACTED

TELEMETRY_COMPONENTS=["tracing"]
TELEMETRY_EXPORTERS=["otlp_http"]
TELEMETRY_ENDPOINT=http://127.0.0.1:4318/v1/traces
TELEMETRY_OAUTH_PROVIDER=soundcloud
TELEMETRY_DEPLOYMENT_ENVIRONMENT=soundcloud

WORKERS=4
THREADS=2
